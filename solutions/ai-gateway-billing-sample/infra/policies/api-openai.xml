<policies>
    <inbound>
        <base />
        <!-- Validate Entra ID JWT (before any backend routing or body mutation) -->
        <validate-azure-ad-token tenant-id="${tenant_id}" output-token-variable-name="jwt">
            <audiences>
                <audience>${api_audience}</audience>
                <audience>${api_client_id}</audience>
            </audiences>
        </validate-azure-ad-token>
        <!-- Extract model deployment name from URL path for routing + metrics -->
        <set-variable name="model-deployment" value="@{
            var path = context.Request.Url.Path;
            var marker = "deployments/";
            var idx = path.IndexOf(marker);
            if (idx >= 0) {
                var rest = path.Substring(idx + marker.Length);
                var end = rest.IndexOf('/');
                return end >= 0 ? rest.Substring(0, end) : rest;
            }
            return "unknown";
        }" />
        <!-- Store requested model before any fallback occurs -->
        <set-variable name="requested-model" value="@((string)context.Variables["model-deployment"])" />
        <set-variable name="served-model" value="@((string)context.Variables["model-deployment"])" />
        <set-variable name="fallback-reason" value="" />
        <!-- Fallback mapping (injected from Terraform) -->
        <set-variable name="fallback-map" value="${fallback_map_json}" />
        <!-- Route to backend based on model name -->
        <choose>
%{ if enable_gemini ~}
            <when condition="@(new [] { ${gemini_models_csv} }.Contains((string)context.Variables["model-deployment"]))">
                <!-- Gemini backend: rewrite URL, set Google API key auth -->
                <set-backend-service id="set-gemini-backend" backend-id="${gemini_backend_id}" />
                <set-variable name="is-gemini" value="true" />
                <!-- Rewrite Azure-style path to Gemini OpenAI-compatible path -->
                <set-variable name="gemini-operation" value="@{
                    var path = context.Request.Url.Path;
                    var marker = "deployments/";
                    var idx = path.IndexOf(marker);
                    if (idx >= 0) {
                        var rest = path.Substring(idx + marker.Length);
                        var slash = rest.IndexOf('/');
                        return slash >= 0 ? rest.Substring(slash + 1) : "";
                    }
                    return "";
                }" />
                <rewrite-uri template="@("/" + (string)context.Variables["gemini-operation"])" copy-unmatched-params="false" />
                <!-- Inject model into request body for Gemini -->
                <set-body>@{
                    var body = context.Request.Body.As<JObject>(preserveContent: true);
                    body["model"] = (string)context.Variables["model-deployment"];
                    return body.ToString();
                }</set-body>
            </when>
%{ endif ~}
            <otherwise>
                <!-- Foundry backend with managed identity auth -->
                <set-backend-service id="set-chat-backend" backend-id="${chat_backend_id}" />
                <set-variable name="is-gemini" value="false" />
                <authentication-managed-identity resource="https://cognitiveservices.azure.com/" />
            </otherwise>
        </choose>
        <!-- Buffer request body to allow retry with different model -->
        <set-variable name="original-body" value="@(context.Request.Body.As<string>(preserveContent: true))" />
        <!-- Build fallback URL (used by send-request if primary fails) -->
        <set-variable name="foundry-base-url" value="${foundry_endpoint}openai" />
        <!-- Emit token metrics to Application Insights (inbound-only policy) -->
        <llm-emit-token-metric namespace="${metric_namespace}">
            <dimension name="API ID" />
            <dimension name="Subscription ID" />
            <dimension name="User ID" />
            <dimension name="Operation ID" />
            <dimension name="Client IP" value="@(context.Request.IpAddress)" />
            <dimension name="Model" value="@((string)context.Variables["requested-model"])" />
        </llm-emit-token-metric>
        <!-- Semantic cache lookup — skip for Gemini (different embeddings provider) -->
        <choose>
            <when condition="@((string)context.Variables["is-gemini"] != "true")">
                <llm-semantic-cache-lookup
                    score-threshold="${cache_score_threshold}"
                    embeddings-backend-id="${embeddings_backend_id}"
                    embeddings-backend-auth="system-assigned"
                    ignore-system-messages="true"
                    max-message-count="10">
                    <vary-by>@(context.Subscription.Id)</vary-by>
                    <vary-by>@((string)context.Variables["model-deployment"])</vary-by>
                </llm-semantic-cache-lookup>
            </when>
        </choose>
    </inbound>
    <backend>
        <forward-request buffer-request-body="true" />
    </backend>
    <outbound>
        <base />
        <!-- Check if backend returned an error that should trigger fallback -->
        <choose>
            <when condition="@{
                var statusCode = context.Response.StatusCode;
                if (statusCode != 429 && statusCode < 500) return false;
                var currentModel = (string)context.Variables["served-model"];
                var fallbackJson = (string)context.Variables["fallback-map"];
                var fallbackMap = JObject.Parse(fallbackJson);
                return fallbackMap[currentModel] != null;
            }">
                <!-- Determine fallback model and reason -->
                <set-variable name="fallback-reason" value="@(context.Response.StatusCode == 429 ? "rate-limited" : "server-error")" />
                <set-variable name="served-model" value="@{
                    var currentModel = (string)context.Variables["served-model"];
                    var fallbackJson = (string)context.Variables["fallback-map"];
                    var fallbackMap = JObject.Parse(fallbackJson);
                    return (string)fallbackMap[currentModel];
                }" />
                <!-- Build fallback URL with the cheaper model deployment -->
                <set-variable name="fallback-url" value="@{
                    var baseUrl = (string)context.Variables["foundry-base-url"];
                    var fallbackModel = (string)context.Variables["served-model"];
                    var path = context.Request.Url.Path;
                    var marker = "deployments/";
                    var idx = path.IndexOf(marker);
                    var afterDeployments = path.Substring(idx + marker.Length);
                    var slash = afterDeployments.IndexOf('/');
                    var operation = slash >= 0 ? afterDeployments.Substring(slash) : "";
                    return baseUrl + "/deployments/" + fallbackModel + operation + "?" + context.Request.Url.QueryString;
                }" />
                <!-- Retry against fallback model using send-request -->
                <send-request mode="new" response-variable-name="fallback-response" timeout="120" ignore-error="false">
                    <set-url>@((string)context.Variables["fallback-url"])</set-url>
                    <set-method>POST</set-method>
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@((string)context.Variables["original-body"])</set-body>
                    <authentication-managed-identity resource="https://cognitiveservices.azure.com/" />
                </send-request>
                <!-- Replace the original error response with the fallback response -->
                <return-response response-variable-name="fallback-response">
                    <set-header name="x-served-model" exists-action="override">
                        <value>@((string)context.Variables["served-model"])</value>
                    </set-header>
                    <set-header name="x-fallback-reason" exists-action="override">
                        <value>@((string)context.Variables["fallback-reason"])</value>
                    </set-header>
                </return-response>
            </when>
        </choose>
        <!-- Normal path: add observability headers -->
        <set-header name="x-served-model" exists-action="override">
            <value>@((string)context.Variables["served-model"])</value>
        </set-header>
        <!-- Store response in semantic cache (Foundry only, skip on fallback) -->
        <choose>
            <when condition="@((string)context.Variables["is-gemini"] != "true" && (string)context.Variables["served-model"] == (string)context.Variables["requested-model"])">
                <llm-semantic-cache-store duration="${cache_duration}" />
            </when>
        </choose>
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
