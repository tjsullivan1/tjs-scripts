### -----------------------------------------------------------------------
### 7. Test rate limiting — send many requests to hit Standard tier limit
###    (Run this repeatedly to see 429 responses with remaining-tokens header)
### -----------------------------------------------------------------------
POST {{gateway}}/openai/deployments/{{model1}}/chat/completions?api-version=2024-12-01-preview
api-key: {{alphaKey}}
Authorization: Bearer {{alphaAuth.response.body.access_token}}
Content-Type: application/json

{
  "messages": [
    { "role": "user", "content": "Write a 500-word essay about cloud computing." }
  ],
  "max_completion_tokens": 500
}

### -----------------------------------------------------------------------
### 8. List models (GET endpoint test)
### -----------------------------------------------------------------------
GET {{gateway}}/openai/models?api-version=2024-12-01-preview
api-key: {{alphaKey}}
Authorization: Bearer {{alphaAuth.response.body.access_token}}

